# === Polymarket ===
POLY_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY
POLY_FUNDER_ADDRESS=0x_YOUR_FUNDER_ADDRESS
POLY_SIGNATURE_TYPE=0
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137

# === Strategy ===
# Minimum consecutive ticks in same direction to trigger signal
MOMENTUM_TICKS=4
# Minimum BTC price change (%) over window to confirm momentum
MOMENTUM_MIN_CHANGE_PCT=0.03
# Max slippage in basis points
MAX_SLIPPAGE_BPS=300
# Trade size in USD
TRADE_SIZE_USD=5.0
# Max acceptable price for a BUY (e.g. 0.65 = never buy above 65c)
MAX_BUY_PRICE=0.65
# Min price to consider selling (exit)
MIN_SELL_PRICE=0.35
# Seconds before market end to stop trading
MARKET_END_BUFFER_SECONDS=120
# Seconds before market end to force exit
FORCE_EXIT_SECONDS=60

# === Risk ===
MAX_DAILY_LOSS_USD=50.0
MAX_OPEN_POSITIONS=3
MAX_POSITION_SIZE_USD=50.0
KILL_SWITCH=false

# === Execution ===
FOK_MAX_RETRIES=3
FOK_RETRY_DELAY_MS=200

# === External prices ===
# Binance and Coinbase are used by default via ccxt (no keys needed for public tickers)

# === Paper trading ===
PAPER_TRADING=true
